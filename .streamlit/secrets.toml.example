# Concept: Mukesh Kesharwani
# Contact: mukesh.kesharwani@adobe.com
#
# Streamlit Community Cloud: App settings → Secrets — paste and replace placeholders.
# Register Okta callback (must match exactly, trailing slash):
# https://aemgovau-secmon.streamlit.app/
OKTA_REDIRECT_URI = "https://aemgovau-secmon.streamlit.app/"
STREAMLIT_APP_URL = "https://aemgovau-secmon.streamlit.app/"

# Bootstrap admin for Settings page (when OIDC not yet configured)
SETTINGS_ADMIN_USER = "mkesharw"
# Set a real password for production. If omitted or left as placeholder, the app
# accepts the built-in default: TryMein2026 (capital M).
SETTINGS_ADMIN_PASSWORD = "TryMein2026"

# Okta OIDC (can also be saved via Settings UI → writes auth_config.json locally)
OKTA_DOMAIN = "your-org.okta.com"
OKTA_CLIENT_ID = "your_client_id"
OKTA_CLIENT_SECRET = "your_client_secret"
OKTA_AUTH_SERVER_ID = "default"
OKTA_SCOPE = "openid profile email"

# Optional: explicit redirect URI (defaults to app URL)
# OKTA_REDIRECT_URI = "https://your-app.streamlit.app/"

# Optional: HMAC key for signed OAuth state if client secret not yet set
# OKTA_STATE_SIGNING_KEY = "long-random-string"
