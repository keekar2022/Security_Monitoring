# Local development for Streamlit dashboard (streamlit run app.py)

# Settings gate (before Okta is configured)
SETTINGS_ADMIN_USER=admin
SETTINGS_ADMIN_PASSWORD=change-me

# Okta OIDC (optional — or configure via Settings UI)
# OKTA_DOMAIN=your-org.okta.com
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# OKTA_AUTH_SERVER_ID=default
# OKTA_SCOPE=openid profile email
# OKTA_REDIRECT_URI=http://localhost:8501/

# Data directory (JSONL metrics)
DATA_DIR=data
