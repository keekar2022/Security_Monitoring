{
  "version": "1.0.0",
  "last_updated": "2026-02-04",
  "description": "API endpoint definitions for Trend Micro Vision One - Production v3.0 Only",
  "maintainer": "Mukesh Kesharwani (mkesharw@adobe.com)",
  "base_path": "/v3.0",
  "endpoints": {
    "kubernetes": {
      "generate_token": {
        "path": "/v3.0/containerSecurity/kubernetesClusters/{id}/token/device",
        "method": "POST",
        "description": "Generate bootstrap token for Kubernetes cluster device registration",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "50/hour",
        "request_format": "json",
        "response_format": "json"
      },
      "list_clusters": {
        "path": "/v3.0/containerSecurity/kubernetesClusters",
        "method": "GET",
        "description": "List all Kubernetes clusters",
        "auth_required": true,
        "rate_limit": "100/hour",
        "pagination": true
      },
      "get_cluster": {
        "path": "/v3.0/containerSecurity/kubernetesClusters/{id}",
        "method": "GET",
        "description": "Get specific cluster details",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "200/hour"
      },
      "delete_cluster": {
        "path": "/v3.0/containerSecurity/kubernetesClusters/{id}",
        "method": "DELETE",
        "description": "Delete a Kubernetes cluster",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "50/hour"
      }
    },
    "devices": {
      "list": {
        "path": "/v3.0/asrm/attackSurfaceDevices",
        "method": "GET",
        "description": "Get discovered devices (attack surface). Beta equivalent: /beta/xdr/riskInsights/attackSurfaceDevices",
        "auth_required": true,
        "rate_limit": "300/hour",
        "pagination": {
          "enabled": true,
          "type": "nextLink",
          "max_per_page": 1000
        },
        "query_params": {
          "top": {
            "description": "Number of results per page",
            "type": "integer",
            "default": 50,
            "maximum": 1000,
            "example": "?top=1000"
          },
          "skip": {
            "description": "Number of results to skip",
            "type": "integer",
            "example": "?skip=100"
          }
        },
        "response": {
          "items": "Array of device objects (id, deviceName, etc.)",
          "totalCount": "Total count",
          "nextLink": "URL for next page (if available)"
        }
      },
      "get_device": {
        "path": "/v3.0/eiqs/endpoints/{id}",
        "method": "GET",
        "description": "Get device details (EIQS)",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "300/hour"
      },
      "get_device_cves": {
        "path": "/v3.0/asrm/vulnerableDevices",
        "method": "GET",
        "description": "Get CVEs detected in a device. Set device id in TMV1-Filter header: id eq '<deviceId>'",
        "auth_required": true,
        "rate_limit": "300/hour",
        "headers": {
          "TMV1-Filter": "OData filter, e.g. id eq '<deviceId>'"
        },
        "response": {
          "items": "Array of vulnerable device objects with cveRecords[]"
        }
      },
      "isolate": {
        "path": "/v3.0/response/endpoints/isolate",
        "method": "POST",
        "description": "Isolate an endpoint from network",
        "auth_required": true,
        "rate_limit": "50/hour"
      }
    },
    "alerts": {
      "list": {
        "path": "/v3.0/workbench/alerts",
        "method": "GET",
        "description": "Get security alerts",
        "auth_required": true,
        "rate_limit": "300/hour",
        "pagination": true
      },
      "get_alert": {
        "path": "/v3.0/workbench/alerts/{id}",
        "method": "GET",
        "description": "Get specific alert details",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "300/hour"
      },
      "update_status": {
        "path": "/v3.0/workbench/alerts/{id}/status",
        "method": "PATCH",
        "description": "Update alert status",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "100/hour"
      }
    },
    "threats": {
      "file_reputation": {
        "path": "/v3.0/threatintel/fileReputations",
        "method": "POST",
        "description": "Check file reputation",
        "auth_required": true,
        "rate_limit": "200/hour"
      },
      "suspicious_objects": {
        "path": "/v3.0/threatintel/suspiciousObjects",
        "method": "POST",
        "description": "Get suspicious object information",
        "auth_required": true,
        "rate_limit": "200/hour"
      }
    },
    "cloud_posture": {
      "list_report_configs": {
        "path": "/v3.0/cloudPosture/reportConfigurations",
        "method": "GET",
        "description": "List all report configurations",
        "auth_required": true,
        "rate_limit": "100/hour",
        "pagination": true
      },
      "create_report_config": {
        "path": "/v3.0/cloudPosture/reportConfigurations",
        "method": "POST",
        "description": "Create a new report configuration",
        "auth_required": true,
        "rate_limit": "50/hour"
      },
      "delete_report_config": {
        "path": "/v3.0/cloudPosture/reportConfigurations/{id}",
        "method": "DELETE",
        "description": "Delete a report configuration",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "50/hour"
      }
    },
    "cloud_risk_management": {
      "list_accounts": {
        "path": "/v3.0/cloudRiskManagement/accounts",
        "method": "GET",
        "description": "List all connected cloud accounts (AWS, Azure, GCP) with resource counts",
        "auth_required": true,
        "rate_limit": "300/hour",
        "pagination": false,
        "response": {
          "count": "Total number of accounts",
          "items": "Array of account objects with id, name, provider, awsAccountId, resourceCount, timestamps"
        },
        "query_params": {
          "provider": {
            "description": "Filter by cloud provider",
            "type": "string",
            "options": ["aws", "azure", "gcp"],
            "example": "?provider=aws"
          }
        }
      },
      "get_account": {
        "path": "/v3.0/cloudRiskManagement/accounts/{id}",
        "method": "GET",
        "description": "Get specific cloud account details",
        "required_params": ["id"],
        "auth_required": true,
        "rate_limit": "300/hour"
      }
    },
    "vulnerabilities": {
      "list_cloud_vm": {
        "path": "/v3.0/cloudVulnerabilities/vms",
        "method": "GET",
        "description": "Get vulnerability data for cloud VMs",
        "auth_required": true,
        "rate_limit": "300/hour",
        "pagination": true
      },
      "list_internet_facing": {
        "path": "/v3.0/cloudVulnerabilities/internetFacingAssets",
        "method": "GET",
        "description": "Get vulnerabilities for internet-facing assets",
        "auth_required": true,
        "rate_limit": "300/hour",
        "pagination": true
      },
      "list_serverless": {
        "path": "/v3.0/cloudVulnerabilities/serverlessFunctions",
        "method": "GET",
        "description": "Get vulnerability data for serverless functions",
        "auth_required": true,
        "rate_limit": "300/hour",
        "pagination": true
      }
    }
  }
}
